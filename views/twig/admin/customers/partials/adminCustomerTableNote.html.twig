<div class="table-container">
    <table class="table" id="tableMpNote">
        <thead>
            <tr>
                <th>Messaggio</th>
                <th>Creato il</th>
                <th>Operatore</th>
                <th>Azioni</th>
            </tr>
        </thead>
        <tbody>
        {% for note in notes %}
            <tr data-id-message="{{ note.id_mpnote }}">
                <td>{{ note.content }}</td>
                <td>{{ note.date_add | date('d/m/Y H:i:s') }}</td>
                <td>{{ note.employee_firstname }} {{ note.employee_lastname }}</td>
                <td>
                    <button class="btn btn-primary btn-sm" onclick="editNoteDetails({{ note.id_mpnote }})" title="modifica">
                        <span class="material-icons">edit</span>
                    </button>
                    <button class="btn btn-danger btn-sm" onclick="deleteNote({{ note.id_mpnote }})" title="elimina">
                        <span class="material-icons">delete</span>
                    </button>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>